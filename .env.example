# ============================
# CRM Отдел продаж — переменные окружения
# ============================

# База данных PostgreSQL (Neon)
# Получите эту строку после регистрации на neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# Секрет для сессий (любая случайная строка, минимум 32 символа)
# Сгенерируйте: openssl rand -hex 32
SESSION_SECRET="change-me-to-random-string-at-least-32-chars-long"
